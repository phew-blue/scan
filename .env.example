# Copy this file to .env and fill in the values.
# docker compose will load .env automatically.

# Database password (used by both postgres and app services)
SCAN_DB_PASSWORD=scan

# OIDC provider settings — obtain from your identity provider
SCAN_OIDC_ISSUER=https://<your-oidc-issuer>
SCAN_OIDC_CLIENT_ID=<your-client-id>
SCAN_OIDC_CLIENT_SECRET=<your-client-secret>
SCAN_OIDC_REDIRECT_URL=http://localhost:8080/auth/callback

# Session signing secret — must be at least 32 characters, keep it secret
SCAN_SESSION_SECRET=<random-32-char-string>

# Optional: password gate before OIDC login
# SCAN_ACCESS_PASSWORD=<bcrypt-hash-or-plaintext>
